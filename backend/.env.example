# ============================================================
# .env.example — copy to .env and fill real values
# NEVER commit .env to version control
# ============================================================
# Railway: use ${{Postgres.DATABASE_URL}} and ${{Redis.REDIS_URL}}
#          for the database and Redis service reference variables.
# ============================================================

# ── Aplicação ────────────────────────────────────────────────
APP_NAME=Hermes
APP_VERSION=1.0.0
ENVIRONMENT=production
DEBUG=false
FRONTEND_URL=https://hermesapp.com.br

# ── Segurança (OBRIGATÓRIO) ───────────────────────────────────
# Gere com: openssl rand -hex 32
SECRET_KEY=GENERATE_RANDOM_STRING_32_CHARS_MIN
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Database (Railway PostgreSQL) ────────────────────────────
# Railway injeta automaticamente — copie a referência abaixo
DATABASE_URL=${{Postgres.DATABASE_URL}}
# Local dev:
# DATABASE_URL=postgresql+psycopg://saas_user:dev_password_123@localhost:5432/saas_financeiro

# ── Redis (Railway Redis) ─────────────────────────────────────
# Railway injeta automaticamente — copie a referência abaixo
REDIS_URL=${{Redis.REDIS_URL}}
CELERY_BROKER_URL=${{Redis.REDIS_URL}}
CELERY_RESULT_BACKEND=${{Redis.REDIS_URL}}
CACHE_TTL=300
# Local dev:
# REDIS_URL=redis://localhost:6379/0

# ── WhatsApp (Meta Cloud API) ─────────────────────────────────
WHATSAPP_PROVIDER=cloud_api
WHATSAPP_ACCESS_TOKEN=COLOCAR_TOKEN_AQUI
WHATSAPP_PHONE_NUMBER_ID=1132740066586311
WHATSAPP_BUSINESS_ACCOUNT_ID=2094674678136582
WHATSAPP_VERIFY_TOKEN=meu_token_secreto_de_verificacao
WHATSAPP_API_VERSION=v21.0

# ── IA ────────────────────────────────────────────────────────
# openai | claude
AI_PROVIDER=claude
ANTHROPIC_API_KEY=COLOCAR_KEY_AQUI
ANTHROPIC_MODEL=claude-sonnet-4-5
OPENAI_API_KEY=COLOCAR_QUANDO_TIVER
OPENAI_MODEL=gpt-4o-mini
AI_TEMPERATURE=0.3

# ── Áudio (Whisper via OpenAI) ───────────────────────────────
WHISPER_MODEL=whisper-1

# ── Storage (MinIO / S3) ─────────────────────────────────────
STORAGE_PROVIDER=minio
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=saas-files
MINIO_USE_SSL=False

# ── Logging ──────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── Rate Limiting ────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000

# ============================================================
# .env.example — copy to .env and fill real values
# NEVER commit .env to version control
# ============================================================

# ── App ─────────────────────────────────────────────────────
ENVIRONMENT=development
DEBUG=True
APP_NAME=SaaS Financeiro
APP_VERSION=0.1.0
APP_PORT=8000
FRONTEND_URL=http://localhost:3000

# ── Security (REQUIRED) ──────────────────────────────────────
# Generate with: openssl rand -hex 32
SECRET_KEY=change-me-to-a-random-64-char-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ── PostgreSQL ───────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=saas_user
POSTGRES_PASSWORD=your_postgres_password
POSTGRES_DB=saas_financeiro
DATABASE_URL=postgresql+psycopg://saas_user:your_postgres_password@localhost:5432/saas_financeiro

# ── Redis ────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_URL=redis://localhost:6379/0
CACHE_TTL=300

# ── Celery ───────────────────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── AI Providers (at least one required) ─────────────────────
# openai | claude
AI_PROVIDER=openai

OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-5

AI_TEMPERATURE=0.3

# ── Audio (Whisper via OpenAI) ───────────────────────────────
WHISPER_MODEL=whisper-1

# ── WhatsApp ─────────────────────────────────────────────────
# evolution (active) | cloud_api (after Meta business verification)
# See WHATSAPP_MIGRATION.md for migration plan.
WHATSAPP_PROVIDER=evolution

# Meta Cloud API (fill after business account verification)
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_VERIFY_TOKEN=your_webhook_verify_token
WHATSAPP_API_VERSION=v21.0

# Evolution API (active temporary provider)
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=your_evolution_api_key
EVOLUTION_INSTANCE=saas-financeiro

# ── Storage (MinIO / S3) ─────────────────────────────────────
# minio | s3
STORAGE_PROVIDER=minio

MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=your_minio_password
MINIO_BUCKET=saas-files
MINIO_USE_SSL=False

# ── Logging ──────────────────────────────────────────────────
# DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# ── Rate Limiting ────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000